PORT=8081
HOST=0.0.0.0
BASE_URL=http://YOUR_LAN_IP:8081
MONGO_URI=mongodb://127.0.0.1:27017/nokta_academy
JWT_SECRET=replace_with_secure_secret_at_least_32_characters
JWT_EXPIRES_IN=15m
REFRESH_SECRET=replace_with_refresh_secret_at_least_32_characters
REFRESH_EXPIRES_IN=7d
CSRF_SECRET=replace_with_csrf_secret_at_least_32_characters
CSRF_HEADER_NAME=x-csrf-token
CSRF_COOKIE_NAME=csrf_token
CSRF_ALLOW_LEGACY_SECRET=true
BODY_LIMIT=10mb
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=120
READ_RATE_LIMIT_MAX=2400
WRITE_RATE_LIMIT_MAX=480
AUTH_RATE_LIMIT_MAX=10
PASSWORD_RESET_EXPIRES_MINUTES=30
EMAIL_VERIFICATION_EXPIRES_HOURS=24
PHONE_VERIFICATION_EXPIRES_MINUTES=10
BCRYPT_ROUNDS=12
ENABLE_JOBS=true
DEFAULT_BRANCH_CODE=HQ
AI_PROVIDER_ENABLED=false
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_MODEL=gpt-4o-mini
AI_ALLOW_SENSITIVE_EXTERNAL=false

# Public URLs (links in email/SMS)
PUBLIC_APP_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8081
INTEGRATIONS_STRICT=false

# Email — dev: console or Mailhog (SMTP_HOST=localhost SMTP_PORT=1025)
EMAIL_ENABLED=true
EMAIL_MODE=console
EMAIL_FROM=Nokta Academy <noreply@localhost>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SMS — dev: console; production: twilio or http gateway
SMS_ENABLED=true
SMS_MODE=console
SMS_DEFAULT_COUNTRY_CODE=93
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SMS_HTTP_URL=
SMS_HTTP_API_KEY=

# Payments
PAYMENT_PROVIDER=manual
PAYMENT_MODE=sandbox
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# TLS (reverse proxy / production)
TRUST_PROXY=true
FORCE_HTTPS=false
HSTS_MAX_AGE=31536000
ALLOW_LAN_ORIGINS=true
MOBILE_RESPONSE_CACHE_TTL_MS=8000
MOBILE_VERBOSE_LOGS=false
