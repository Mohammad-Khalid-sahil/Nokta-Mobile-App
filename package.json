{
  "name": "nokta-academy-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --exec \"node --max-old-space-size=4096 -r ts-node/register/transpile-only src/server.ts\"",
    "dev:with-mongo": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev-with-mongo.ps1",
    "mongo:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-mongo.ps1",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test:exam-score": "ts-node src/utils/examScore.test.ts",
    "migrate:result-scores": "ts-node src/scripts/migrate_result_scores_unified.ts",
    "test": "npm run test:http-errors && npm run test:schedule && npm run test:timetable && npm run test:salary && npm run test:tax && npm run test:payroll-commission && npm run test:ai-results && npm run test:ai-insight && npm run test:study-recommendation && npm run test:ai-results-access && npm run test:authorize && npm run test:route-policy && npm run test:public-contact && npm run test:jwt && npm run test:exam-score",
    "test:public-contact": "ts-node src/modules/messages/public-contact.schema.test.ts",
    "test:jwt": "ts-node src/utils/jwt.test.ts",
    "test:authorize": "ts-node src/middlewares/authorize.middleware.test.ts",
    "test:route-policy": "ts-node src/services/permissionService.routePolicy.test.ts",
    "test:schedule": "ts-node src/utils/classSchedule.test.ts",
    "test:timetable": "ts-node src/services/timetableValidationService.test.ts",
    "test:http-errors": "ts-node src/utils/httpErrors.test.ts",
    "test:salary": "ts-node src/services/teacherCompensationService.test.ts",
    "test:tax": "ts-node src/services/afghanistanSalaryTaxService.test.ts",
    "test:payroll-commission": "ts-node src/services/payrollCalculation.commission.test.ts",
    "test:ai-results": "ts-node src/modules/ai-results/aiResultAnalysis.service.test.ts",
    "test:ai-insight": "ts-node src/services/aiInsightService.test.ts",
    "test:study-recommendation": "ts-node src/services/studyRecommendationService.test.ts",
    "test:ai-results-access": "ts-node src/modules/ai-results/ai-results.access.test.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "seed:qa": "ts-node src/scripts/reset_and_seed_clean_qa.ts",
    "delete-students-teachers": "ts-node src/scripts/delete_students_teachers.ts",
    "clear-database": "ts-node src/scripts/clear_database.ts",
    "create-super-admin": "ts-node src/scripts/create_super_admin.ts",
    "restore-super-admin": "ts-node src/scripts/restore_super_admin.ts",
    "repair-data-integrity": "ts-node src/scripts/repair_data_integrity.ts",
    "repair-student-relations": "ts-node src/scripts/repair_student_relations.ts",
    "validate-api": "ts-node src/scripts/validate_api_integrity.ts",
    "validate-integrations": "ts-node src/scripts/validate_integrations.ts"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.20",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "helmet": "^7.0.0",
    "jalaliday": "^3.1.1",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.6.2",
    "mongoose": "^7.8.0",
    "nodemailer": "^6.9.16",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.18",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^1.4.13",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^20.16.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.4"
  }
}
