{
  "openapi": "3.0.3",
  "info": {
    "title": "Nokta Academy API",
    "description": "Educational management system API for schools and academies.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:8081", "description": "Local development" }
  ],
  "tags": [
    { "name": "System" },
    { "name": "Auth" },
    { "name": "Users" },
    { "name": "Academic" },
    { "name": "Finance" },
    { "name": "AI Results" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Liveness check",
        "responses": { "200": { "description": "Service is running" } }
      }
    },
    "/health/ready": {
      "get": {
        "tags": ["System"],
        "summary": "Readiness check (includes database)",
        "responses": {
          "200": { "description": "Ready" },
          "503": { "description": "Not ready" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Tokens and user profile" } }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh access token",
        "responses": { "200": { "description": "New tokens" } }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout current session",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Logged out" } }
      }
    },
    "/api/auth/logout-all": {
      "post": {
        "tags": ["Auth"],
        "summary": "Revoke all sessions",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "All sessions revoked" } }
      }
    },
    "/api/users": {
      "get": {
        "tags": ["Users"],
        "summary": "List users",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "User list" } }
      }
    },
    "/api/attendance": {
      "get": {
        "tags": ["Academic"],
        "summary": "Attendance records",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Attendance data" } }
      }
    },
    "/api/finance": {
      "get": {
        "tags": ["Finance"],
        "summary": "Finance overview",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Finance data" } }
      }
    },
    "/api/books": {
      "get": {
        "tags": ["Academic"],
        "summary": "Book inventory",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Books" } }
      }
    },
    "/api/audit": {
      "get": {
        "tags": ["System"],
        "summary": "Audit log",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Audit entries" } }
      }
    },
    "/api/ai-results/me": {
      "get": {
        "tags": ["AI Results"],
        "summary": "Latest AI insight summary for student or parent",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Insight summary payload" } }
      }
    },
    "/api/ai-results/result/{resultId}": {
      "get": {
        "tags": ["AI Results"],
        "summary": "AI insight for a specific result",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "resultId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Insight record" }, "403": { "description": "Forbidden" }, "404": { "description": "Not found" } }
      }
    },
    "/api/ai-results/student/{studentId}": {
      "get": {
        "tags": ["AI Results"],
        "summary": "List AI insights for a student",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "studentId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Insight list" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/ai-results/exam/{examId}": {
      "get": {
        "tags": ["AI Results"],
        "summary": "Exam insights and class analytics",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "examId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Per-student insights and class insight" } }
      }
    },
    "/api/ai-results/generate/{resultId}": {
      "post": {
        "tags": ["AI Results"],
        "summary": "Generate or refresh AI insight for a result",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "resultId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Generated insight" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/ai-results/generate-exam/{examId}": {
      "post": {
        "tags": ["AI Results"],
        "summary": "Generate class-level exam insights",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "examId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Class insight" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
